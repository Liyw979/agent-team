{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "strict": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@shared/*": [
        "src/shared/*"
      ]
    }
  },
  "include": [
    "src/cli/**/*.ts",
    "src/cli/**/*.d.ts",
    "src/runtime/**/*.ts",
    "src/runtime/**/*.d.ts",
    "src/shared/**/*.ts"
  ]
}
